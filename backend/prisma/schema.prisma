// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
  RUNNER
}

enum DeliveryStatus {
  PENDING
  CONFIRMED
  READY_FOR_ASSIGNMENT
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum ProviderOrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  PICKED_UP
  REJECTED_BY_STORE
  CANCELLED
}

enum ProductImportJobStatus {
  VALIDATING
  VALIDATED
  APPLIED
  FAILED
}

enum ProductImportFormat {
  CSV
  XLSX
}

model User {
  id                         String    @id @default(uuid()) @db.Uuid
  email                      String    @unique
  password                   String
  pin                        String? // Hashed transaction PIN for purchases
  name                       String
  roles                      Role[]    @default([CLIENT])
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  emailVerified              Boolean   @default(false)
  verificationToken          String?   @unique
  verificationTokenExpiresAt DateTime?
  mfaSecret                  String? // Stores the TOTP secret
  mfaSetupToken              String? // Stores the temporary Email OTP to access QR
  mfaSetupExpiresAt          DateTime?
  mfaEnabled                 Boolean   @default(false)
  mfaFailedAttempts          Int       @default(0)
  mfaLockUntil               DateTime?
  active                     Boolean   @default(true)
  tokenVersion               Int       @default(1)
  stripeAccountId            String?   @unique // Stores the Connected Account ID for payout routing
  resetPasswordTokenHash     String?   @unique
  resetPasswordExpiresAt     DateTime?
  passwordChangedAt          DateTime?
  lastEmailSentAt            DateTime?

  // Geolocation
  address   String?
  latitude  Float?
  longitude Float?

  // Relations
  orders         Order[]         @relation("ClientOrders")
  runnerProfile  RunnerProfile?
  providerProfile Provider?
  products       Product[]       @relation("ProviderProducts")
  runnerOrders   Order[]         @relation("RunnerOrders")
  providerOrders ProviderOrder[] @relation("ProviderOrders")
  productImportJobs ProductImportJob[]
}

model City {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  products Product[]
  orders   Order[]
  providers Provider[]
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  image_url String?
  createdAt DateTime @default(now())

  // Relations
  products Product[]
  providers Provider[]
}

model Provider {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  slug            String   @unique
  businessName    String
  cityId          String   @db.Uuid
  categoryId      String   @db.Uuid
  description     String
  workshopHistory String
  photos          String[]
  videoUrl        String?
  websiteUrl      String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  city     City     @relation(fields: [cityId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([cityId])
  @@index([categoryId])
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  reference   String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  // Foreign Keys
  providerId String @db.Uuid
  cityId     String @db.Uuid
  categoryId String @db.Uuid

  // Relations
  provider   User        @relation("ProviderProducts", fields: [providerId], references: [id])
  city       City        @relation(fields: [cityId], references: [id])
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([providerId])
  @@index([cityId])
  @@index([categoryId])
  @@index([isActive])
  @@unique([providerId, reference])
}

model Order {
  id         String         @id @default(uuid()) @db.Uuid
  totalPrice Decimal        @db.Decimal(10, 2)
  status     DeliveryStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Foreign Keys
  clientId String  @db.Uuid
  cityId   String  @db.Uuid
  runnerId String? @db.Uuid

  // Relations
  client User  @relation("ClientOrders", fields: [clientId], references: [id])
  city   City  @relation(fields: [cityId], references: [id])
  runner User? @relation("RunnerOrders", fields: [runnerId], references: [id])

  providerOrders ProviderOrder[]

  // Delivery Information
  deliveryAddress String?
  deliveryLat     Float?
  deliveryLng     Float?

  // Payment Tracking (Idempotency)
  paymentRef      String?  @unique
  confirmedAt     DateTime?

  // Runner Matching Fees
  deliveryFee        Decimal  @default(0.00) @db.Decimal(10, 2)
  deliveryDistanceKm Decimal? @db.Decimal(10, 2)
  runnerBaseFee      Decimal? @db.Decimal(10, 2)
  runnerPerKmFee     Decimal? @db.Decimal(10, 2)

  @@index([clientId])
  @@index([cityId])
  @@index([runnerId])
  @@index([status])
}

model ProviderOrder {
  id        String              @id @default(uuid()) @db.Uuid
  status    ProviderOrderStatus @default(PENDING)
  subtotal  Decimal             @db.Decimal(10, 2)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // Foreign Keys
  orderId    String @db.Uuid
  providerId String @db.Uuid

  // Relations
  order    Order @relation(fields: [orderId], references: [id])
  provider User  @relation("ProviderOrders", fields: [providerId], references: [id])

  items OrderItem[]

  @@index([orderId])
  @@index([providerId])
  @@index([status])
}

model OrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  quantity        Int
  priceAtPurchase Decimal @db.Decimal(10, 2)

  // Foreign Keys
  providerOrderId String @db.Uuid
  productId       String @db.Uuid

  // Relations
  providerOrder ProviderOrder @relation(fields: [providerOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@unique([providerOrderId, productId])
  @@index([providerOrderId])
  @@index([productId])
}

model RunnerProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  // Location
  baseLat       Float?
  baseLng       Float?
  maxDistanceKm Float  @default(10.0)

  // Pricing
  priceBase  Decimal @default(2.00) @db.Decimal(10, 2)
  pricePerKm Decimal @default(0.50) @db.Decimal(10, 2)
  minFee     Decimal @default(3.00) @db.Decimal(10, 2)

  // Status & Metrics
  isActive    Boolean  @default(true)
  ratingAvg   Decimal? @db.Decimal(3, 2)
  ratingCount Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])
}
model WebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model ProductImportJob {
  id               String                 @id @default(uuid()) @db.Uuid
  providerId       String                 @db.Uuid
  status           ProductImportJobStatus @default(VALIDATING)
  format           ProductImportFormat
  filename         String
  totalRows        Int                    @default(0)
  validRows        Int                    @default(0)
  createdCount     Int                    @default(0)
  updatedCount     Int                    @default(0)
  failedCount      Int                    @default(0)
  validationErrors Json?
  payload          Json?
  appliedAt        DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  provider User @relation(fields: [providerId], references: [id])

  @@index([providerId, status])
  @@index([createdAt])
}
