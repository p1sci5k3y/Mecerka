{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest",
    "^.+\\.m?js$": "jest-esbuild"
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!(@scure|otplib|@noble|@paralleldrive)/)"
  ]
}