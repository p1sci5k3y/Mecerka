{
  "moduleFileExtensions": ["js", "json", "ts"],
  "globalSetup": "<rootDir>/global-test-setup.ts",
  "globalTeardown": "<rootDir>/global-test-teardown.ts",
  "rootDir": ".",
  "testEnvironment": "node",
  "maxWorkers": 1,
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest",
    "^.+\\.m?js$": "jest-esbuild"
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!(@scure|otplib|@noble|@paralleldrive)/)"
  ]
}
